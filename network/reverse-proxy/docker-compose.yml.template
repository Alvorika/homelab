services:
  nginx:
    image: nginx:latest
    container_name: reverse-proxy
    restart: unless-stopped
    ports:
      - "${BIND_PUBLIC:-0.0.0.0}:80:80"
      - "${BIND_PUBLIC:-0.0.0.0}:443:443"
    volumes:
      - ./nginx.conf:/etc/nginx/nginx.conf:ro
      - ./conf.d:/etc/nginx/conf.d:ro
      - ${TLS_CERT_DIR:-/etc/nginx/ssl}:/etc/nginx/ssl:ro
    networks:
      - global_docker_network

networks:
  global_docker_network:
    external: true
    name: global_docker_network
