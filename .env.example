# Global environment variables
# Copy to .env and adjust for your environment
#
# Before deploying any service, create the shared network:
#   docker network create global_docker_network

# --- Network ---
LAN_SUBNET=192.168.10.0/24
LAN_INTERFACE=enp2s0f1
WAN_INTERFACE=enp2s0f0
GATEWAY_IP=192.168.10.1
SERVER_IP=192.168.10.2
BIND_WEB=127.0.0.1
BIND_DATA=127.0.0.1
BIND_LAN=0.0.0.0
BIND_PUBLIC=0.0.0.0

# --- Domain ---
DOMAIN=lab.internal
TLD=internal

# --- Tailscale ---
TAILSCALE_AUTH_KEY=tskey-auth-...
DERP_DOMAIN=derp.example.com

# --- Proxy (Clash) ---
CLASH_SUBSCRIPTION_URL=https://your-subscription-url
CLASH_EXTERNAL_CONTROLLER_SECRET=generate-a-random-secret

# --- Certificates ---
CERT_EMAIL=admin@example.com
CA_CERT_PATH=/opt/lab/certs/rootCA.pem

# --- Auth (Authelia) ---
AUTHELIA_JWT_SECRET=generate-a-random-secret
AUTHELIA_SESSION_SECRET=generate-a-random-secret
AUTHELIA_STORAGE_ENCRYPTION_KEY=generate-a-random-key
AUTHELIA_SMTP_HOST=smtp.example.com
AUTHELIA_SMTP_USER=user@example.com
AUTHELIA_SMTP_PASSWORD=your-smtp-password
AUTHELIA_SMTP_SENDER=auth@example.com
OIDC_PRIVATE_KEY=replace-with-rendered-multiline-private-key
GITEA_OIDC_CLIENT_SECRET=generate-a-random-secret
GITEA_OIDC_CLIENT_SECRET_HASH=replace-with-authelia-hashed-secret
NEXTCLOUD_OIDC_CLIENT_SECRET=generate-a-random-secret
NEXTCLOUD_OIDC_CLIENT_SECRET_HASH=replace-with-authelia-hashed-secret
OUTLINE_OIDC_CLIENT_SECRET=generate-a-random-secret
OUTLINE_OIDC_CLIENT_SECRET_HASH=replace-with-authelia-hashed-secret
OPENWEBUI_OIDC_CLIENT_SECRET=generate-a-random-secret
OPENWEBUI_OIDC_CLIENT_SECRET_HASH=replace-with-authelia-hashed-secret
JUPYTERHUB_OIDC_CLIENT_SECRET=generate-a-random-secret
JUPYTERHUB_OIDC_CLIENT_SECRET_HASH=replace-with-authelia-hashed-secret

# --- Database ---
POSTGRES_USER=admin
POSTGRES_PASSWORD=change-me
POSTGRES_DB=outline_db
NEXTCLOUD_DB_PASSWORD=change-me
OUTLINE_DB_PASSWORD=change-me

# --- Gitea ---
GITEA_ADMIN_USER=admin
GITEA_ADMIN_PASSWORD=change-me
GITEA_ADMIN_EMAIL=admin@example.com
GITEA_LFS_JWT_SECRET=generate-a-random-secret
GITEA_INTERNAL_TOKEN=generate-a-random-secret
GITEA_OAUTH2_JWT_SECRET=generate-a-random-secret

# --- MinIO ---
MINIO_ROOT_USER=root
MINIO_ROOT_PASSWORD=change-me
OUTLINE_S3_ACCESS_KEY=outline-access-key
OUTLINE_S3_SECRET_KEY=outline-secret-key

# --- Nextcloud ---
NEXTCLOUD_ADMIN_USER=admin
NEXTCLOUD_ADMIN_PASSWORD=change-me
NEXTCLOUD_DATA_DIR=/data/nextcloud/html
NEXTCLOUD_DB_DATA_DIR=/data/postgres/nextcloud
ONLYOFFICE_JWT_SECRET=generate-a-random-secret

# --- Gateway DNS/DHCP ---
DHCP_RANGE_START=192.168.10.100
DHCP_RANGE_END=192.168.10.200

# --- Outline ---
OUTLINE_SECRET_KEY=generate-a-random-secret
OUTLINE_UTILS_SECRET=generate-a-random-secret

# --- Search ---
SEARXNG_SECRET_KEY=generate-a-random-secret

# --- JupyterHub ---
JUPYTERHUB_ADMIN=admin

# --- Samba ---
SAMBA_ADMIN_USER=admin
SAMBA_ADMIN_PASSWORD=change-me
SAMBA_USER=user
SAMBA_USER_PASSWORD=change-me
SAMBA_STORAGE_DIR=/data/storage/user
SAMBA_PUBLIC_DIR=/data/storage/public

# --- LLM ---
WEBUI_SECRET_KEY=generate-a-random-secret
OPEN_WEBUI_PORT=3000

# --- Reverse proxy template ---
SERVICE_DOMAIN=example.lab.internal
UPSTREAM_URL=http://127.0.0.1:3000
TLS_CERT=/etc/nginx/ssl/example.lab.internal/cert.crt
TLS_KEY=/etc/nginx/ssl/example.lab.internal/private.key
CLIENT_MAX_BODY_SIZE=100m
